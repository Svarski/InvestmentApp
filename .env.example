WORKER_INTERVAL_SECONDS=300
WORKER_DRY_RUN=false
WORKER_LOG_LEVEL=INFO
ALERT_STATE_FILE=./data/alert_state.json
# Optional: worker writes portfolio_source here for the dashboard indicator
WORKER_HEARTBEAT_FILE=./data/worker_heartbeat.json

ALERT_CHANNEL=telegram
EMAIL_ENABLED=true

TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_username
SMTP_PASSWORD=your_password
SMTP_USE_TLS=true
EMAIL_FROM=alerts@example.com
EMAIL_TO=you@example.com

WEEKLY_SUMMARY_ENABLED=true
WEEKLY_SUMMARY_CHANNEL=email
WEEKLY_SUMMARY_DAY=sunday
WEEKLY_SUMMARY_HOUR=18
WEEKLY_SUMMARY_TIMEZONE=UTC
WEEKLY_SUMMARY_EMAIL_TO=you@example.com
WEEKLY_SUMMARY_STATE_FILE=./data/weekly_digest_state.json

DAILY_DIGEST_ENABLED=false
DAILY_DIGEST_HOUR=9
DAILY_DIGEST_TIMEZONE=UTC
